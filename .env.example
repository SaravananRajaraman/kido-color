# ─── Firebase Configuration ─────────────────────────────────────────────────
# Copy this file to .env.local and fill in your Firebase project credentials.
# See README.md → "Firebase Setup" for step-by-step instructions.
#
# Without these values the app runs in offline/demo mode — all drawing tools
# and animations work; only cloud save / Google sign-in is disabled.

VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef0123456789abcdef
